{
  "version": 2,
  "name": "brickchat",
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(css|js|assets|manifest.json|sw.js)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/manifest.json",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/manifest+json"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/service-worker.js",
      "destination": "/sw.js"
    }
  ]
}
